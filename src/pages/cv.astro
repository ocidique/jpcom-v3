---
import Layout from "../layouts/Layout.astro";
import DotPattern from "../components/DotPattern.astro";
import YearLabel from "../components/YearLabel.astro";
---

<Layout title="CV" description="CV" showBackground={false}>
  <div class="mx-auto max-w-5xl space-y-6 lg:space-y-12">
    <div class="mx-auto max-w-3xl">
      <div>
        <p
          class="text-center font-medium text-zinc-900 uppercase dark:text-zinc-300"
        >
          Curriculum Vitae
        </p>
        <h1
          class="mt-6 flex flex-col items-center justify-center text-center text-6xl font-medium text-zinc-900 lg:mt-12 lg:flex-row lg:space-x-6 dark:text-zinc-300"
        >
          <span>developer</span>
          <span class="block lg:hidden">&</span>
          <span
            class="font-cursive -mt-4 hidden lg:block"
            style={{ fontSize: "100px" }}
          >
            &
          </span>
          <span class="font-cursive -mt-10" style={{ fontSize: "120px" }}>
            designer
          </span>
        </h1>
      </div>
      <p class="mt-12 text-center text-orange-600">
        #fullstack #frontend #design #ux #ui
      </p>
      {
        /* <p class="text-xl lg:text-3xl text-zinc-900 dark:text-zinc-300 leading-relaxed tracking-wider py-6 text-center px-12 lg:px-0">
        Hello, is it me you're looking for? A talented modern web software developer? The one who can design and
        code apps that are good looking, diamond cut sharp and accessible! 💎
      </p> */
      }
    </div>

    <div class="flex flex-col lg:flex-row lg:space-x-12">
      <div class="relative hidden w-full px-12 lg:block lg:w-2/5">
        <div class="absolute z-10 text-gray-300 dark:text-zinc-700">
          <DotPattern />
        </div>
        <div
          class="absolute z-10"
          style={{
            top: "280px",
            left: "160px",
            background: "#9acd32",
            width: "200px",
            height: "200px",
            transform: "rotate(-30deg)",
          }}
        >
        </div>
        <div
          class="absolute z-10 h-0 w-0 border"
          style={{
            top: "380px",
            left: "150px",
            transform: "rotate(40deg)",
            borderWidth: "0 100px 170px 100px",
            borderColor: "transparent transparent #cd5c5c transparent",
          }}
        >
        </div>
        <div
          class="relative z-20 w-80 transform rounded-xl bg-gradient-to-r from-[#6EE7B7] via-[#3B82F6] to-[#9333EA] p-1 transition-all hover:scale-[1.01]"
          style={{ top: "40px", left: "40px" }}
        >
          <div class="dark:bg-one-dark space-y-8 rounded-lg bg-white p-4">
            <p class="text-zinc-900 italic dark:text-zinc-300">
              “Juho has been a valuable asset in our team. He has shown great
              multi-talent as a designer and front-end developer”
            </p>
            <p class="text-zinc-900 italic dark:text-zinc-300">
              “Juho is a dedicated and hardworking person. He always gives input
              and ideas to develop every day work.”
            </p>
            {
              /* <div class="flex flex-col space-y-4">
              <CTA to="#">Portfolio coming soon</CTA>
              <CTA to="#">Printable CV coming soon</CTA>
              <CTA to="#">Check the portfolio</CTA>
              <CTA to="#">Printable CV</CTA>
            </div> */
            }
          </div>
        </div>
      </div>

      <div class="w-full space-y-8 text-zinc-900 lg:w-3/5">
        <div class="space-y-4">
          <h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-300">
            Profile
          </h2>
          <p class="text-lg text-zinc-900 dark:text-zinc-300">
            I am a versatile full-stack developer with a creative mindset, and
            strong design skills. With over 10 years of experience in the field,
            I have developed a keen eye for detail and a passion for creating
            exceptional user experiences. My expertise spans across the entire
            software development life cycle, from conceptualization to
            deployment.
          </p>
          <p class="text-lg text-zinc-900 dark:text-zinc-300">
            As a full-stack developer, I am well-versed in both front-end and
            back-end development technologies and have a proven track record of
            delivering high-quality projects. With my unique blend of technical
            and creative skills, I am confident in my ability to take on any
            project and exceed expectations. A lifelong learning mentality
            ensures that new technologies and other latest and greatest
            solutions are welcome.
          </p>
        </div>

        <div class="space-y-4">
          <h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-300">
            Expertise
          </h2>
          <ul class="ml-4 space-y-2 text-lg">
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300"
                >Hands-on coding skillz</span
              >
            </li>
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300"
                >HTML, CSS, JavaScript, Typescript, React</span
              >
            </li>
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300"
                >UI/UX, Design Systems, Accessibility, RWD</span
              >
            </li>
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300">
                Wireframing, UI Protyping, Visual Design, Figma, Sketch
              </span>
            </li>
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300"
                >Python, Django, NodeJS, Java, PHP</span
              >
            </li>
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300">REST, GraphQL</span
              >
            </li>
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300"
                >Database Design, Schemas, SQL, NoSQL</span
              >
            </li>
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300">Git</span>
            </li>
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300">Azure, AWS</span>
            </li>
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300"
                >Agile Methodologies, XP, Scrum Master</span
              >
            </li>
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300">
                Project management, maintaining project status and priorities
              </span>
            </li>
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300">
                Roles I've worked as:{" "}
                <span class="font-semibold">
                  full-stack developer, front-end developer, software designer,
                  UI/UX designer, design system lead
                </span>
              </span>
            </li>
          </ul>
        </div>
        <div class="space-y-4">
          <h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-300">
            Languages
          </h2>
          <ul class="ml-4 space-y-2 text-lg">
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300"
                >Finnish as native 🇫🇮</span
              >
            </li>
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300">
                Professional working proficiency in English 🇬🇧
              </span>
            </li>
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300"
                >Måttlig kunskap i svenska 🇸🇪</span
              >
            </li>
            <li class="list-disc text-orange-600">
              <span class="text-zinc-900 dark:text-zinc-300">
                Aprendizaje de conceptos básicos del español 🇪🇸
              </span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="max-w-3xl space-y-8 lg:mx-auto">
      <div class="space-y-4 px-4 lg:px-0">
        <h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-300">
          Education
        </h2>
        <ul class="flex flex-col space-y-6 lg:space-y-10">
          <li
            class="flex flex-col space-y-4 border-t border-zinc-300 py-6 lg:flex-row lg:space-y-0 lg:space-x-4 dark:border-zinc-700"
          >
            <div class="w-full lg:w-36">
              <YearLabel>2017 - 2022</YearLabel>
            </div>
            <div class="w-full space-y-4">
              <p class="text-lg font-semibold text-zinc-900 dark:text-zinc-300">
                M.Sc. in CSE - University of Oulu
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Studied my master's alongside with full time job.
                Entrepreneurship as minor studies. The subject of the master's
                thesis was related to the design systems.
              </p>
              {
                /* <p class="text-zinc-900 dark:text-zinc-300 text-lg">
                Having few years apart from bachelor's studies made a huge difference. Blog post coming about the
                journey...
              </p> */
              }
              {/* <CTA to="#">Read about my master's journey</CTA> */}
            </div>
          </li>

          <li
            class="flex flex-col space-y-4 border-t border-zinc-300 py-6 lg:flex-row lg:space-y-0 lg:space-x-4 dark:border-zinc-700"
          >
            <div class="w-full lg:w-36">
              <YearLabel>2009 - 2013</YearLabel>
            </div>
            <div class="w-full space-y-4">
              <p class="text-lg font-semibold text-zinc-900 dark:text-zinc-300">
                B.Eng. - Oulu University of Applied Sciences
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Computer Software Engineering. Orientation to mobile development
                using Qt. Business as minor studies.
              </p>
              {
                /* <CTA to="#">Read about my journey to becoming an engineer</CTA> */
              }
            </div>
          </li>
        </ul>
      </div>
      <div class="space-y-4 px-4 pb-12 lg:px-0">
        <h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-300">
          Experience
        </h2>
        <ul class="flex flex-col space-y-10">
          <li
            class="flex flex-col space-y-4 border-t border-zinc-300 py-6 lg:flex-row lg:space-y-0 lg:space-x-4 dark:border-zinc-700"
          >
            <div class="w-full lg:w-36">
              <YearLabel>2025 - </YearLabel>
            </div>
            <div class="w-full space-y-4">
              <p class="text-lg font-semibold text-zinc-900 dark:text-zinc-300">
                Full-Stack Developer & Designer, Partner - Heroe Oy
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                New ventures as a Partner in a newly founded company called{" "}
                <a
                  href="https://www.heroe.fi/"
                  class="text-orange-500 hover:underline"
                >
                  Heroe
                </a>{" "}
                which is a part of the{" "}
                <a
                  href="https://luotocompany.fi/"
                  class="text-orange-500 hover:underline"
                >
                  Luoto Company Ecosystem
                </a>
                .
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Currently working with tech stack: Java, Spring, React,
                TypeScript
              </p>
            </div>
          </li>

          <li
            class="flex flex-col space-y-4 border-t border-zinc-300 py-6 lg:flex-row lg:space-y-0 lg:space-x-4 dark:border-zinc-700"
          >
            <div class="w-full lg:w-36">
              <YearLabel>2023 - 2025</YearLabel>
            </div>
            <div class="w-full space-y-4">
              <p class="text-lg font-semibold text-zinc-900 dark:text-zinc-300">
                Lead Software Developer - Siili Solutions Oyj
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Long term e-service development. Python, Django, HTML, CSS,
                JavaScript, TypeScript, React, GraphQL, Tailwind, Design system,
                Playwright, Azure
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Hybrid full-stack developer: responsible for UI/UX design and
                front-end development.
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Haallas merged to Siili Solutions Oyj.
              </p>
            </div>
          </li>

          <li
            class="flex flex-col space-y-4 border-t border-zinc-300 py-6 lg:flex-row lg:space-y-0 lg:space-x-4 dark:border-zinc-700"
          >
            <div class="w-full lg:w-36">
              <YearLabel>2022</YearLabel>
            </div>
            <div class="w-full space-y-4">
              <p class="text-lg font-semibold text-zinc-900 dark:text-zinc-300">
                Lead Software Developer - Haallas Finland Oy
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Long term e-service development. Python, Django, HTML, CSS,
                JavaScript, TypeScript, React, GraphQL, Tailwind, Design system,
                Playwright, Azure
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Hybrid full-stack developer: responsible for UI/UX design and
                front-end development.
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Participated in various technology, design and marketing
                activities.
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Valamis consultancy goes under own brand. Acquired by Siili
                Solutions Oyj.
              </p>
            </div>
          </li>

          <li
            class="flex flex-col space-y-4 border-t border-zinc-300 py-6 lg:flex-row lg:space-y-0 lg:space-x-4 dark:border-zinc-700"
          >
            <div class="w-full lg:w-36">
              <YearLabel>2018 - 2021</YearLabel>
            </div>
            <div class="w-full space-y-4">
              <p class="text-lg font-semibold text-zinc-900 dark:text-zinc-300">
                Senior Software Developer - Valamis Group Oy
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Long term e-service development. Python, Django, HTML, CSS,
                JavaScript, React, GraphQL, Tailwind, Design system, Azure
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Hybrid full-stack developer: responsible for UI/UX design and
                front-end development.
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Organized multiple local tech talks and demo coffees.
              </p>
            </div>
          </li>

          <li
            class="flex flex-col space-y-4 border-t border-zinc-300 py-6 lg:flex-row lg:space-y-0 lg:space-x-4 dark:border-zinc-700"
          >
            <div class="w-full lg:w-36">
              <YearLabel>2017 - 2018</YearLabel>
            </div>
            <div class="w-full space-y-4">
              <p class="text-lg font-semibold text-zinc-900 dark:text-zinc-300">
                Senior Software Developer - Arcusys Oy
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Long term e-service development. Python, Django, REST, HTML,
                CSS, React, JavaScript.
              </p>
            </div>
          </li>

          <li
            class="flex flex-col space-y-4 border-t border-zinc-300 py-6 lg:flex-row lg:space-y-0 lg:space-x-4 dark:border-zinc-700"
          >
            <div class="w-full lg:w-36">
              <YearLabel>2013 - 2017</YearLabel>
            </div>
            <div class="w-full space-y-4">
              <p class="text-lg font-semibold text-zinc-900 dark:text-zinc-300">
                Software Developer - Arcusys Oy
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Various e-service projects. Java, HTML, CSS, JavaScript.
              </p>
            </div>
          </li>

          <li
            class="flex flex-col space-y-4 border-t border-zinc-300 py-6 lg:flex-row lg:space-y-0 lg:space-x-4 dark:border-zinc-700"
          >
            <div class="w-full lg:w-36">
              <YearLabel>2011 - 2014</YearLabel>
            </div>
            <div class="w-full space-y-4">
              <p class="text-lg font-semibold text-zinc-900 dark:text-zinc-300">
                Web Developer - Freelance
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Wordpress development for various customers. PHP, HTML, CSS.
              </p>
            </div>
          </li>

          <li
            class="flex flex-col space-y-4 border-t border-zinc-300 py-6 lg:flex-row lg:space-y-0 lg:space-x-4 dark:border-zinc-700"
          >
            <div class="w-full lg:w-36">
              <YearLabel>2012</YearLabel>
            </div>
            <div class="w-full space-y-4">
              <p class="text-lg font-semibold text-zinc-900 dark:text-zinc-300">
                Web Developer - Koodiviidakko Oy
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Project gig. Leffatykki.com back-end migration. PHP, HTML, CSS.
              </p>
            </div>
          </li>

          <li
            class="flex flex-col space-y-4 border-t border-zinc-300 py-6 lg:flex-row lg:space-y-0 lg:space-x-4 dark:border-zinc-700"
          >
            <div class="w-full lg:w-36">
              <YearLabel>2012</YearLabel>
            </div>
            <div class="w-full space-y-4">
              <p class="text-lg font-semibold text-zinc-900 dark:text-zinc-300">
                Web Developer - ZEF Solutions Oy
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Wordpress development. PHP, HTML, CSS.
              </p>
            </div>
          </li>

          <li
            class="flex flex-col space-y-4 border-t border-zinc-300 py-6 lg:flex-row lg:space-y-0 lg:space-x-4 dark:border-zinc-700"
          >
            <div class="w-full lg:w-36">
              <YearLabel>2010</YearLabel>
            </div>
            <div class="w-full space-y-4">
              <p class="text-lg font-semibold text-zinc-900 dark:text-zinc-300">
                Web Developer - DreamIT
              </p>
              <p class="text-lg text-zinc-900 dark:text-zinc-300">
                Product development using PHP, CakePHP, HTML, CSS, JavaScript.
              </p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
