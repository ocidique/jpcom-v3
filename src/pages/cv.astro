---
import Layout from "../layouts/Layout.astro";
import YearLabel from "../components/YearLabel.astro";

// Generate scattered tracking stars for a galaxy effect around the testimonials
const stars = Array.from({ length: 40 }).map(() => {
  const angle = Math.random() * Math.PI * 2;
  const radius = Math.random() * 90 + 140; // Defines the galaxy ring width
  return {
    top: 250 + Math.sin(angle) * radius + "px", // 250 is the center of the 500x500 rotating wrapper
    left: 250 + Math.cos(angle) * radius + "px",
    size: Math.random() * 2 + 0.5,
    opacity: Math.random() * 0.6 + 0.2,
  };
});
