---
import Layout from "../layouts/Layout.astro";
import Logo from "../assets/logo.svg";
---

<Layout showBackground={true} showFooter={false}>
  <div
    class="relative mx-auto flex max-w-3xl flex-col justify-center py-20 text-zinc-900 dark:text-zinc-100"
  >
    <!-- Desktop view: Huge centered logo with absolutely positioned technical text -->
    <div class="hidden md:block">
      <div class="relative left-22.5 text-zinc-900 dark:text-orange-500">
        <Logo />
      </div>

      <p class="absolute top-37.5 left-1 font-mono">// developer / designer</p>
      <p class="absolute top-87.5 left-105 w-full font-mono">
        // creative maker / nature lover
      </p>
      <p class="absolute top-118.75 left-105 font-mono">// based in finland</p>
      <div class="flex w-full justify-center pt-24">
        <p class="font-mono">// only development is permanent</p>
      </div>
    </div>

    <!-- Mobile view: Hidden large logo, tidy left-margin text stack -->
    <div class="flex flex-col gap-4 pt-10 pl-6 font-mono md:hidden">
      <p>// developer / designer</p>
      <p>// creative maker / nature lover</p>
      <p>// based in finland</p>
      <p class="pt-8 text-sm">// only development is permanent</p>
    </div>
  </div>
</Layout>
