---
import Layout from "../layouts/Layout.astro";
import Logo from "../assets/logo.svg";
---

<Layout showBackground={true} showFooter={false}>
  <div
    class="relative mx-auto flex max-w-3xl flex-col justify-center py-20 text-zinc-900 dark:text-zinc-100"
  >
    <div class="relative left-22.5 text-zinc-900 dark:text-orange-500">
      <Logo />
    </div>

    <p class="absolute top-37.5 left-1 font-mono">// developer / designer</p>
    <p class="absolute top-87.5 left-105 w-full font-mono">
      // creative maker / nature lover
    </p>
    <p class="absolute top-118.75 left-105 font-mono">// based in finland</p>
    <div class="inline-flex flex-wrap items-center justify-around pt-24">
      <p class="font-mono">// only development is permanent</p>
    </div>
  </div>
</Layout>
