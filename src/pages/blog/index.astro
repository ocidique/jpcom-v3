---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort((a, b) => {
  // First, sort by pinned status (pinned posts first)
  if (a.data.pinned && !b.data.pinned) {
    return -1;
  }
  if (!a.data.pinned && b.data.pinned) {
    return 1;
  }

  // Then sort by publication date (newest first)
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

// Separate the first 3 posts (which include pinned) for the featured section
const featuredPosts = posts.slice(0, 3);
const restPosts = posts.slice(3);

// Generate scattered tracking stars for a galaxy effect around the header
const stars = Array.from({ length: 30 }).map(() => {
  const angle = Math.random() * Math.PI * 2;
  const radius = Math.random() * 80 + 40; // Defines the galaxy ring width
  return {
    top: 100 + Math.sin(angle) * radius + "px", // center of rotation wrapper
    left: 100 + Math.cos(angle) * radius + "px",
    size: Math.random() * 2 + 0.5,
    opacity: Math.random() * 0.6 + 0.2,
  };
});
---

<Layout>
  <section class="mx-auto w-full max-w-5xl space-y-12 pb-16">
    <div class="relative mt-8 mb-16 flex items-center space-y-4">
      {/* Scattered Galaxy Stars behind the header */}
      <div
        class="absolute z-10 origin-center animate-[spin_120s_linear_infinite]"
        style={{
          width: "200px",
          height: "200px",
          top: "-50px",
          left: "-20px",
        }}
      >
        {
          stars.map((star) => (
            <div
              class="absolute rounded-full bg-slate-400 dark:bg-zinc-300"
              style={{
                top: star.top,
                left: star.left,
                width: `${star.size}px`,
                height: `${star.size}px`,
                opacity: star.opacity,
              }}
            />
          ))
        }
      </div>

      <h1
        class="relative z-20 text-3xl leading-9 font-extrabold tracking-tight sm:text-4xl sm:leading-10 md:text-5xl md:leading-14"
      >
        <span id="typewriter"></span><span class="animate-cursor-blink">|</span>
      </h1>
      <p
        class="text-lg leading-normal tracking-wider text-zinc-900 lg:text-2xl dark:text-zinc-300"
      >
      </p>
    </div>

    <script>
      function typeWriterEffect() {
        const text = "I write sometimes.";
        const element = document.getElementById("typewriter");
        if (!element) return;

        element.textContent = "";
        let i = 0;

        function type() {
          if (i < text.length) {
            element.textContent += text.charAt(i);
            i++;
            setTimeout(type, 80 + Math.random() * 50); // randomize typing speed slightly
          }
        }

        setTimeout(type, 300); // initial delay before typing starts
      }

      // Run on initial load
      typeWriterEffect();

      // Re-run if Astro View Transitions are used
      document.addEventListener("astro:page-load", typeWriterEffect);
    </script>

    {/* Featured Cards */}
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
      {
        featuredPosts.map((post) => (
          <a
            href={`/blog/${post.id}/`}
            class="group flex flex-col justify-between space-y-4 rounded-xl border-2 border-dashed border-slate-500/40 p-6 transition-colors hover:border-indigo-600 dark:border-slate-400/40 dark:hover:border-indigo-400"
          >
            <div class="space-y-2">
              <div class="flex items-center space-x-2">
                {post.data.pinned && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 384 512"
                    class="h-4 w-4 text-orange-500 dark:text-orange-400"
                    fill="currentColor"
                  >
                    <path d="M32 32C32 14.33 46.33 0 64 0H320C337.7 0 352 14.33 352 32C352 49.67 337.7 64 320 64H290.5L301.9 212.2C338.6 232.1 367.5 265.4 381.4 306.9L382.4 309.9C385.6 319.6 383.1 330.4 377.1 338.7C371.9 347.1 362.3 352 352 352H32C21.71 352 12.05 347.1 6.04 338.7C.0259 330.4-1.611 319.6 1.642 309.9L2.644 306.9C16.47 265.4 45.42 232.1 82.14 212.2L93.54 64H64C46.33 64 32 49.67 32 32zM224 384V480C224 497.7 209.7 512 192 512C174.3 512 160 497.7 160 480V384H224z" />
                  </svg>
                )}
                <h2 class="text-xl font-bold tracking-tight text-zinc-900 transition-colors group-hover:text-indigo-600 dark:text-zinc-100 dark:group-hover:text-indigo-400">
                  {post.data.title}
                </h2>
              </div>
              {post.data.description && (
                <p class="line-clamp-3 text-base text-zinc-600 dark:text-zinc-400">
                  {post.data.description}
                </p>
              )}
            </div>
            <time class="shrink-0 font-mono text-sm text-zinc-500 dark:text-zinc-500">
              <FormattedDate date={post.data.pubDate} />
            </time>
          </a>
        ))
      }
    </div>

    {/* Rest of the posts */}
    <div class="space-y-6 pt-6">
      <ul class="flex flex-col space-y-8 lg:space-y-10">
        {
          restPosts.map((post) => (
            <li class="group flex flex-col space-y-2 border-b border-zinc-200 pb-8 last:border-0 last:pb-0 lg:flex-row lg:items-baseline lg:justify-between lg:space-y-0 dark:border-zinc-800">
              <a
                href={`/blog/${post.id}/`}
                class="flex w-full flex-col space-y-2 lg:w-3/4"
              >
                <div class="flex items-center space-x-2">
                  {post.data.pinned && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 384 512"
                      class="h-4 w-4 text-zinc-500 dark:text-zinc-400"
                      fill="currentColor"
                    >
                      <path d="M32 32C32 14.33 46.33 0 64 0H320C337.7 0 352 14.33 352 32C352 49.67 337.7 64 320 64H290.5L301.9 212.2C338.6 232.1 367.5 265.4 381.4 306.9L382.4 309.9C385.6 319.6 383.1 330.4 377.1 338.7C371.9 347.1 362.3 352 352 352H32C21.71 352 12.05 347.1 6.04 338.7C.0259 330.4-1.611 319.6 1.642 309.9L2.644 306.9C16.47 265.4 45.42 232.1 82.14 212.2L93.54 64H64C46.33 64 32 49.67 32 32zM224 384V480C224 497.7 209.7 512 192 512C174.3 512 160 497.7 160 480V384H224z" />
                    </svg>
                  )}
                  <h2 class="text-xl font-bold tracking-tight text-zinc-900 transition-colors group-hover:text-indigo-600 md:text-2xl dark:text-zinc-100 dark:group-hover:text-indigo-400">
                    {post.data.title}
                  </h2>
                </div>
                {post.data.description && (
                  <p class="line-clamp-2 text-base text-zinc-600 dark:text-zinc-400">
                    {post.data.description}
                  </p>
                )}
              </a>
              <time class="shrink-0 pt-2 font-mono text-sm text-zinc-500 lg:w-1/4 lg:pt-0 lg:text-right dark:text-zinc-500">
                <FormattedDate date={post.data.pubDate} />
              </time>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>
