---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import { Image } from "astro:assets";
import LogoBlock from "../components/blog/LogoBlock.astro";
import PhotoMeta from "../components/blog/PhotoMeta.astro";

type Props = CollectionEntry<"blog">["data"];

const {
  title,
  description = "",
  pubDate,
  updatedDate,
  heroImage,
  heroImageAlt = "",
  heroImageCreditText = "",
  heroImageCreditLink = "",
  heroImageFullWidth = false,
} = Astro.props;

// Generate scattered tracking stars for a galaxy effect around the heading
const stars = Array.from({ length: 40 }).map(() => {
  const angle = Math.random() * Math.PI * 2;
  // Creating a wider ellipse by using different multipliers for x and y
  const xRadius = Math.random() * 200 + 100;
  const yRadius = Math.random() * 60 + 30;

  return {
    top: 75 + Math.sin(angle) * yRadius + "px", // Centered in a 150px tall container
    left: 250 + Math.cos(angle) * xRadius + "px", // Centered in a 500px wide container
    size: Math.random() * 2 + 0.5,
    opacity: Math.random() * 0.6 + 0.2,
  };
});
---

<main class="relative z-30 min-h-screen scroll-smooth">
  <article class="flex min-h-screen flex-col justify-between space-y-12">
    <div
      class="relative flex flex-col items-center justify-center space-y-6 pt-12 pb-8 text-center"
    >
      {/* Scattered Galaxy Stars behind the header */}
      <div
        class="pointer-events-none absolute z-10 origin-center animate-[spin_120s_linear_infinite]"
        style={{
          width: "500px",
          height: "150px",
          top: "80px",
        }}
      >
        {
          stars.map((star) => (
            <div
              class="absolute rounded-full bg-slate-400 dark:bg-zinc-300"
              style={{
                top: star.top,
                left: star.left,
                width: `${star.size}px`,
                height: `${star.size}px`,
                opacity: star.opacity,
              }}
            />
          ))
        }
      </div>

      <h1
        class="relative z-20 text-center text-3xl leading-9 font-extrabold tracking-tight sm:text-4xl sm:leading-10 md:text-5xl md:leading-14"
      >
        {title}
      </h1>

      <div class="relative z-20 text-center font-mono">
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <div class="last-updated-on">
              Last updated on <FormattedDate date={updatedDate} />
            </div>
          )
        }
      </div>
    </div>

    {
      heroImage && (
        <div class="flex flex-col items-center">
          <Image
            src={heroImage}
            alt={heroImageAlt}
            class={heroImageFullWidth ? "w-full" : "max-w-2xl"}
          />
          {heroImageAlt && (
            <PhotoMeta
              alt={heroImageAlt}
              credit={heroImageCreditText}
              url={heroImageCreditLink}
            />
          )}
        </div>
      )
    }

    <div
      id="content"
      class="post-content space-y-10 px-4 text-zinc-900 dark:text-zinc-200"
    >
      <slot />
    </div>

    <!-- <div class="px-4">
      <LogoBlock />
    </div> -->
  </article>
</main>
