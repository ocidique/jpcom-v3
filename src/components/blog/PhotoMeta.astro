---
interface Props {
  alt: string;
  credit: string;
  url?: string;
}

const { alt, credit, url } = Astro.props;
---

<div
  class="mx-auto max-w-2xl px-4 py-1 text-sm text-zinc-600 lg:px-0 dark:text-zinc-400"
>
  {alt} Photo by:{" "}
  {
    url ? (
      <a
        href={url}
        target="_blank"
        class="hover:text-orange-500 dark:hover:text-orange-500"
        style="border-bottom: 0 !important;"
      >
        {credit}
      </a>
    ) : (
      <span>{credit}</span>
    )
  }
</div>
